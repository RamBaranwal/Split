    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "mongoose": "^9.7.0",
    "multer": "^2.0.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^8.0.16"
  }
}
